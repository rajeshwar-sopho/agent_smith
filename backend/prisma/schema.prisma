
// backend/prisma/schema.prisma
generator client {
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Soul {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  content     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bots        Bot[]
}

model Bot {
  id          String   @id @default(cuid())
  name        String
  model       String   @default("claude-sonnet-4-6")
  status      String   @default("idle")
  containerId String?
  soulId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  soul      Soul?          @relation(fields: [soulId], references: [id])
  tasks     Task[]
  logs      Log[]
  questions HumanQuestion[]
  memories  Memory[]
}

model Task {
  id          String   @id @default(cuid())
  botId       String
  title       String
  description String
  status      String   @default("pending")
  plan        String?
  result      String?
  tokenUsage  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot       Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)
  logs      Log[]
  subtasks  Subtask[]
  questions HumanQuestion[]
  memories  Memory[]
}

model Subtask {
  id     String @id @default(cuid())
  taskId String
  title  String
  status String @default("pending")
  order  Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Log {
  id        String   @id @default(cuid())
  botId     String
  taskId    String?
  level     String   @default("info")
  message   String
  meta      String?
  createdAt DateTime @default(now())

  bot  Bot   @relation(fields: [botId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])
}

model HumanQuestion {
  id         String    @id @default(cuid())
  botId      String
  taskId     String?
  question   String
  context    String?
  answer     String?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  answeredAt DateTime?

  bot  Bot   @relation(fields: [botId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])
}

// ─── Agent Memory ─────────────────────────────────────────────────────────────

model Memory {
  id        String   @id @default(cuid())
  botId     String
  taskId    String?
  type      String   @default("task_outcome") // 'task_outcome' | 'error_pattern' | 'insight'
  title     String
  content   String   // Compact summary generated by Claude (≤200 words)
  keywords  String   @default("[]") // JSON array of keyword strings for BM25 search
  createdAt DateTime @default(now())

  bot  Bot   @relation(fields: [botId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])
}

// ─── Skills ───────────────────────────────────────────────────────────────────

model Skill {
  id          String      @id @default(cuid())
  name        String      @unique  // slug e.g. "stripe-api", "web-scraping"
  description String
  repoUrl     String?     // optional GitHub URL
  context     String      // README/instructions injected into agent prompts
  tags        String      @default("[]")  // JSON array
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  files       SkillFile[]
}

model SkillFile {
  id        String @id @default(cuid())
  skillId   String
  filename  String
  language  String  @default("python")  // python | javascript | text
  content   String

  skill     Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

// ─── Shared Program Library ───────────────────────────────────────────────────

model SharedProgram {
  id          String   @id @default(cuid())
  name        String   @unique   // e.g. "csv_parser", "web_scraper"
  description String
  language    String             // python | javascript
  filename    String             // actual file on disk in shared-programs volume
  tags        String   @default("[]")  // JSON string array e.g. '["csv","data"]'
  usageCount  Int      @default(0)
  createdBy   String             // botId
  updatedBy   String?            // botId of last updater
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
