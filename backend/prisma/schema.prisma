// backend/prisma/schema.prisma
generator client {
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bot {
  id          String   @id @default(cuid())
  name        String
  model       String   @default("claude-sonnet-4-6") // full model string e.g. "claude-sonnet-4-5", "gemini-2.0-flash"
  status      String   @default("idle")   // idle | planning | researching | executing | waiting_for_human | done | failed
  containerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks    Task[]
  logs     Log[]
  questions HumanQuestion[]
}

model Task {
  id          String   @id @default(cuid())
  botId       String
  title       String
  description String
  status      String   @default("pending") // pending | planning | executing | waiting | done | failed
  plan        String?  // JSON array of subtasks
  result      String?
  tokenUsage  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot      Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  logs     Log[]
  subtasks Subtask[]
  questions HumanQuestion[]
}

model Subtask {
  id       String  @id @default(cuid())
  taskId   String
  title    String
  status   String  @default("pending") // pending | doing | done | failed
  order    Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Log {
  id        String   @id @default(cuid())
  botId     String
  taskId    String?
  level     String   @default("info") // info | warn | error | tool
  message   String
  meta      String?  // JSON metadata
  createdAt DateTime @default(now())

  bot  Bot   @relation(fields: [botId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])
}

model HumanQuestion {
  id        String   @id @default(cuid())
  botId     String
  taskId    String?
  question  String
  context   String?
  answer    String?
  status    String   @default("pending") // pending | answered
  createdAt DateTime @default(now())
  answeredAt DateTime?

  bot  Bot   @relation(fields: [botId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])
}
